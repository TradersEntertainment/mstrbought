# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here  # Channel username (e.g. @channel) or chat ID

# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here

# Admin Password Configuration (For Web Dashboard Controls)
ADMIN_PASSWORD=your_admin_password_here  # Set a password to protect "Force Check" and "Test Alert" buttons

# Database Configuration
DB_PATH=mstr_state.db  # For Railway volume mount, set this to /data/mstr_state.db

# Polling Interval Configuration (in seconds)
POLL_INTERVAL_NORMAL=300
POLL_INTERVAL_CRITICAL=2

# Dividend Model Configuration
# Baseline = outstanding face value ($M) of each preferred series BEFORE the
# tracked ATM data window begins (read them from the latest 10-Q).
# 0 = model only counts ATM sales observed by this bot.
PREFERRED_BASELINE_AS_OF=2026-02-01
STRF_BASELINE_M=0
STRK_BASELINE_M=0
STRD_BASELINE_M=0
STRC_BASELINE_M=0
# STRC pays a variable monthly rate announced by MSTR — keep this current
STRC_ANNUAL_RATE=0.10
